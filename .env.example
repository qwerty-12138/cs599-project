# ===================================
# CS599 Agentic RAG 系统 — 环境变量
# ===================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 阿里云百炼 (DashScope) LLM 配置
DASHSCOPE_API_KEY=sk-*****
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
# ===================================
# 数据库 (Docker 部署时使用默认值即可)
# ===================================
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://agent:agent_secret@postgres:5432/agent_db

# PostgreSQL
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_secret
POSTGRES_DB=agent_db

# ===================================
# 向量数据库
# ===================================
# 选项 A: ChromaDB (开发默认)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# 选项 B: Milvus (生产可选)
# MILVUS_HOST=milvus
# MILVUS_PORT=19530

# 向量维度
VECTOR_DIM=1536

# ===================================
# LangFuse 可观测性 (可选)
# ===================================
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# ===================================
# Prometheus / Grafana
# ===================================
GRAFANA_ADMIN_PASSWORD=admin

# ===================================
# 沙箱配置
# ===================================
SANDBOX_TIMEOUT=30
SANDBOX_MEM_LIMIT=256m
SANDBOX_CPU_SHARES=512

# ===================================
# API 配置
# ===================================
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===================================
# 记忆配置
# ===================================
SHORT_TERM_TTL=86400           # 短期记忆 TTL (秒，默认 24h)
MAX_SHORT_TERM_MESSAGES=50     # 短期记忆最大消息数
MAX_LONG_TERM_RESULTS=5        # 长期记忆检索条数
SESSION_IDLE_TIMEOUT=1800      # 会话空闲超时 (秒，默认 30min)

# ===================================
# MCP 配置
# ===================================
MCP_TOOL_TIMEOUT=30            # MCP 工具调用超时 (秒)
MCP_MAX_RETRIES=2              # MCP 重试次数
MCP_SERVER_CONFIG_DIR=./config/mcp  # MCP 服务器配置持久化目录
